{
  "compilerOptions": {

    "module": "NodeNext",
    "target": "ESNext",

    "types": ["node"],
    "lib": ["esnext"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,



    "verbatimModuleSyntax": false,

    "isolatedModules": true,
    "moduleDetection": "force",

    "skipLibCheck": true
  }
}